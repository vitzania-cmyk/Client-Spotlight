<title>Q2 2026 CSM Performance Report | TalentPop</title>
<style>
  :root {
    --poptarts: #FF6B9D;
    --poptarts-light: #FFE8F2;
    --rocketpops: #5B8DEF;
    --rocketpops-light: #EAF0FF;
    --lolipops: #9B59B6;
    --lolipops-light: #F3E8FF;
    --green: #22C55E;
    --green-dark: #15803D;
    --green-light: #DCFCE7;
    --amber: #F59E0B;
    --red: #EF4444;
    --red-light: #FEE2E2;
    --gold: #F5C518;
    --dark: #1A1A2E;
    --mid: #2E3250;
    --text: #333;
    --subtext: #666;
    --bg: #F7F8FC;
    --card: #FFFFFF;
    --radius: 14px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #1A1A2E 0%, #2E3250 60%, #3D2B6B 100%);
    color: white; text-align: center; padding: 64px 24px 80px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(34,197,94,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 30%, rgba(91,141,239,0.15) 0%, transparent 60%);
  }
  .hero-eyebrow { font-size: 13px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 16px; position: relative; }
  .hero h1 { font-size: clamp(32px, 6vw, 56px); font-weight: 800; line-height: 1.1; position: relative; margin-bottom: 12px; }
  .hero h1 span { color: #22C55E; }
  .hero-sub { font-size: 16px; color: rgba(255,255,255,0.65); max-width: 520px; margin: 0 auto; position: relative; }

  /* ── STATS BAR ── */
  .stats-bar { display: flex; justify-content: center; flex-wrap: wrap; background: var(--mid); }
  .stat-item { flex: 1; min-width: 160px; text-align: center; padding: 22px 16px; border-right: 1px solid rgba(255,255,255,0.08); animation: fadeUp 0.5s ease both; }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-size: 32px; font-weight: 800; color: white; line-height: 1; }
  .stat-num.good { color: #22C55E; }
  .stat-num.gold { color: var(--gold); }
  .stat-label { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; text-transform: uppercase; letter-spacing: 1px; }
  .stat-goal { font-size: 11px; color: rgba(255,255,255,0.3); margin-top: 3px; }

  /* ── SECTIONS ── */
  .section { max-width: 1100px; margin: 0 auto; padding: 48px 24px 0; }
  .section-title { font-size: 22px; font-weight: 700; color: var(--dark); margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }
  .section-title::after { content: ''; flex: 1; height: 2px; background: linear-gradient(to right, rgba(0,0,0,0.08), transparent); }

  /* ── GOAL CARDS ── */
  .goal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 48px; }
  .goal-card { background: var(--card); border-radius: var(--radius); box-shadow: 0 2px 12px rgba(0,0,0,0.07); overflow: hidden; animation: fadeUp 0.5s ease both; }
  .goal-header { padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; }
  .goal-title { font-size: 14px; font-weight: 700; color: white; letter-spacing: 0.3px; }
  .goal-check { font-size: 22px; }
  .goal-body { padding: 20px; }
  .goal-numbers { display: flex; align-items: flex-end; gap: 16px; margin-bottom: 14px; }
  .goal-actual { font-size: 44px; font-weight: 800; line-height: 1; }
  .goal-vs { display: flex; flex-direction: column; gap: 2px; padding-bottom: 6px; }
  .goal-vs-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--subtext); font-weight: 600; }
  .goal-target { font-size: 18px; font-weight: 700; color: var(--subtext); }
  .goal-bar-wrap { height: 8px; background: #eee; border-radius: 99px; overflow: hidden; margin-bottom: 10px; }
  .goal-bar { height: 100%; border-radius: 99px; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); width: 0; }
  .goal-note { font-size: 12px; color: var(--green-dark); font-weight: 600; }

  /* ── POD CARDS ── */
  .pod-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 48px; }
  .pod-card { background: var(--card); border-radius: var(--radius); box-shadow: 0 2px 12px rgba(0,0,0,0.07); overflow: hidden; animation: fadeUp 0.5s ease both; }
  .pod-header { padding: 18px 20px; display: flex; align-items: center; justify-content: space-between; }
  .pod-header-left { display: flex; align-items: center; gap: 10px; }
  .pod-dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.4); flex-shrink: 0; }
  .pod-name { font-size: 17px; font-weight: 700; color: white; }
  .pod-manager { font-size: 12px; color: rgba(255,255,255,0.7); }
  .pod-rate-badge { font-size: 26px; font-weight: 800; color: white; }
  .pod-body { padding: 16px 20px; }
  .pod-bar-wrap { height: 8px; background: #eee; border-radius: 99px; margin-bottom: 14px; overflow: hidden; }
  .pod-bar { height: 100%; border-radius: 99px; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); width: 0; }
  .pod-meta { display: flex; gap: 16px; flex-wrap: wrap; }
  .pod-meta-item { font-size: 13px; color: var(--subtext); }
  .pod-meta-item strong { color: var(--text); font-weight: 600; }
  .pod-meta-item .good { color: var(--green-dark); }

  /* ── PODIUM ── */
  .podium-wrap { display: flex; justify-content: center; align-items: flex-end; gap: 16px; padding: 24px 0 40px; flex-wrap: wrap; }
  .podium-card { text-align: center; border-radius: var(--radius); overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.12); animation: popIn 0.6s cubic-bezier(0.34,1.56,0.64,1) both; }
  .podium-card.p1 { width: 220px; animation-delay: 0.2s; }
  .podium-card.p2 { width: 190px; animation-delay: 0.1s; }
  .podium-card.p3 { width: 180px; animation-delay: 0.3s; }
  .podium-top { padding: 24px 20px 16px; background: var(--card); }
  .podium-medal { font-size: 36px; display: block; margin-bottom: 8px; }
  .podium-name { font-size: 16px; font-weight: 700; color: var(--dark); margin-bottom: 4px; }
  .podium-pod { font-size: 12px; color: var(--subtext); margin-bottom: 12px; }
  .podium-rate { font-size: 42px; font-weight: 800; line-height: 1; }
  .podium-rate small { font-size: 18px; font-weight: 500; }
  .podium-detail { font-size: 12px; color: var(--subtext); margin-top: 4px; }
  .podium-base { padding: 10px; font-size: 13px; font-weight: 700; color: white; letter-spacing: 1px; }
  .p1 .podium-base { background: var(--gold); }
  .p2 .podium-base { background: var(--silver, #A8B2C1); }
  .p3 .podium-base { background: #CD7F32; }
  .p1 .podium-rate { color: #D4A800; }
  .p2 .podium-rate { color: #A8B2C1; }
  .p3 .podium-rate { color: #CD7F32; }
  @keyframes popIn { from { opacity: 0; transform: scale(0.85); } to { opacity: 1; transform: scale(1); } }

  /* ── ANALYSIS CARDS ── */
  .analysis-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 20px; margin-bottom: 64px; }
  .analysis-card { background: var(--card); border-radius: var(--radius); box-shadow: 0 2px 12px rgba(0,0,0,0.07); overflow: hidden; }
  .analysis-header { padding: 16px 20px; background: var(--dark); }
  .analysis-title { font-size: 15px; font-weight: 700; color: white; }
  .analysis-sub { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 2px; }
  .analysis-row { display: flex; align-items: center; gap: 12px; padding: 11px 20px; border-bottom: 1px solid #F0F0F0; }
  .analysis-row:last-child { border-bottom: none; }
  .analysis-label { font-size: 13px; color: var(--text); width: 128px; flex-shrink: 0; }
  .analysis-bar-wrap { flex: 1; height: 8px; background: #eee; border-radius: 99px; overflow: hidden; }
  .analysis-bar { height: 100%; border-radius: 99px; width: 0; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); }
  .analysis-pct { font-size: 13px; font-weight: 700; width: 52px; text-align: right; flex-shrink: 0; }
  .analysis-count { font-size: 11px; color: var(--subtext); width: 44px; text-align: right; flex-shrink: 0; }

  /* ── FOOTER ── */
  .footer { background: var(--mid); color: rgba(255,255,255,0.4); text-align: center; padding: 28px; font-size: 13px; margin-top: 64px; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
</style>
</head>
